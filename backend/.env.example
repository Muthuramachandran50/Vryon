# ================================================================
# BACKEND ENVIRONMENT VARIABLES
# ================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to Git!
# ================================================================


# ---------------------------------------------------------------
# Hugging Face (required for Gradio / IDM-VTON model access)
# Get your token at: https://huggingface.co/settings/tokens
# ---------------------------------------------------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------------------------------------------------------------
# Gradio Space (which IDM-VTON space to use)
# Default: yisol/IDM-VTON  (public, no auth needed)
# If using a private space, set HF_TOKEN above
# ---------------------------------------------------------------
GRADIO_SPACE=yisol/IDM-VTON


# ---------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000


# ---------------------------------------------------------------
# CORS Origins (comma-separated list of allowed frontend URLs)
# Development:  http://localhost:3000
# Production:   https://your-production-domain.com
# ---------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000


# ---------------------------------------------------------------
# Optional: Replicate API (alternative AI backend)
# Get your token at: https://replicate.com/account/api-tokens
# ---------------------------------------------------------------
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
